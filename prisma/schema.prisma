generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  UMKM
  INVESTOR
  ADMIN
}

enum PitchStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum TxnKind {
  INFLOW
  OUTFLOW
}

enum ReimbursementStatus {
  AUTO_APPROVED
  PENDING_ADMIN_REVIEW
  BLOCKED_PRICE_CHECK
  DISBURSED
  REJECTED
}

enum Sector {
  F_AND_B
  RETAIL
  AGRI
  SERVICES
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedUMKM   UMKM[]        @relation("UMKMOwner")
  investments Investment[]
  posts       CommunityPost[]
  qaPosts     QAPost[]
  fundHoldings IndexFundHolding[]
}

model UMKM {
  id                String   @id @default(cuid())
  ownerId           String
  owner             User     @relation("UMKMOwner", fields: [ownerId], references: [id])
  name              String
  sector            Sector
  ageMonths         Int
  monthlyRevenueIDR BigInt
  fundingTargetIDR  BigInt
  valuationIDR      BigInt
  equityOfferedPct  Float
  story             String
  thumbnailUrl      String?
  location          String
  province          String
  syariahCompliant  Boolean  @default(true)
  aiScore           Int
  sliKScore         Int      @default(70)
  ecomVelocity      Int      @default(60)
  digitalBehavior   Int      @default(70)
  aiScoreOverride   Int?
  overrideReason    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pitch          Pitch?
  bankAccount    BankAccount?
  investments    Investment[]
  reimbursements Reimbursement[]
  posts          CommunityPost[]
  qaPosts        QAPost[]
  fundHoldings   IndexFundHolding[]
}

model Pitch {
  id              String      @id @default(cuid())
  umkmId          String      @unique
  umkm            UMKM        @relation(fields: [umkmId], references: [id], onDelete: Cascade)
  status          PitchStatus @default(DRAFT)
  raisedIDR       BigInt      @default(0)
  minTicketIDR    BigInt      @default(100000)
  deadline        DateTime
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Investment {
  id           String   @id @default(cuid())
  investorId   String
  investor     User     @relation(fields: [investorId], references: [id])
  umkmId       String
  umkm         UMKM     @relation(fields: [umkmId], references: [id])
  amountIDR    BigInt
  equityPct    Float
  createdAt    DateTime @default(now())

  @@index([investorId])
  @@index([umkmId])
}

model BankAccount {
  id            String        @id @default(cuid())
  umkmId        String        @unique
  umkm          UMKM          @relation(fields: [umkmId], references: [id], onDelete: Cascade)
  providerBPR   String
  accountNumber String
  balanceIDR    BigInt        @default(0)
  createdAt     DateTime      @default(now())
  transactions  Transaction[]
}

model Transaction {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  ts            DateTime    @default(now())
  amountIDR    BigInt
  kind          TxnKind
  channel       String
  counterparty  String
  note          String?

  @@index([bankAccountId, ts])
}

model Reimbursement {
  id           String              @id @default(cuid())
  umkmId       String
  umkm         UMKM                @relation(fields: [umkmId], references: [id])
  amountIDR    BigInt
  category     String
  supplier     String?
  description  String
  invoiceUrl   String?
  refPriceIDR  BigInt?
  deltaPct     Float?
  verdict      String?
  status       ReimbursementStatus @default(PENDING_ADMIN_REVIEW)
  rejectReason String?
  createdAt    DateTime            @default(now())
  resolvedAt   DateTime?

  @@index([umkmId, status])
}

model IndexFundHolding {
  id         String   @id @default(cuid())
  investorId String
  investor   User     @relation(fields: [investorId], references: [id])
  umkmId     String
  umkm       UMKM     @relation(fields: [umkmId], references: [id])
  weightPct  Float
  amountIDR  BigInt
  createdAt  DateTime @default(now())

  @@index([investorId])
}

model CommunityPost {
  id        String   @id @default(cuid())
  umkmId    String
  umkm      UMKM     @relation(fields: [umkmId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  imageUrl  String?
  createdAt DateTime @default(now())

  @@index([umkmId, createdAt])
}

model QAPost {
  id        String   @id @default(cuid())
  umkmId    String
  umkm      UMKM     @relation(fields: [umkmId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  parentId  String?
  parent    QAPost?  @relation("QAReply", fields: [parentId], references: [id])
  replies   QAPost[] @relation("QAReply")
  createdAt DateTime @default(now())

  @@index([umkmId, createdAt])
}
